# Platinum Tracker API
#
# Copy this file to .env only when overriding the built-in local defaults.
# Do not add secrets or commit the resulting .env file.

# The API must remain bound to a literal loopback address in v1.
PLATINUM_TRACKER_API_HOST=127.0.0.1
PLATINUM_TRACKER_API_PORT=8000

# Storage defaults to data/, media/, and imports/ under the repository root.
# Uncomment only when custom absolute paths are needed.
# PLATINUM_TRACKER_PROJECT_ROOT=/absolute/path/to/platinum-tracker
# PLATINUM_TRACKER_DATA_DIR=/absolute/path/to/data
# PLATINUM_TRACKER_MEDIA_DIR=/absolute/path/to/media
# PLATINUM_TRACKER_SOURCE_DIR=/absolute/path/to/imports
# PLATINUM_TRACKER_DATABASE_PATH=/absolute/path/to/platinum-tracker.db
